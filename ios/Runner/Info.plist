  <key>NSAppTransportSecurity</key><dict><key>NSAllowsLocalNetworking</key><true/></dict>
  <key>NSBonjourServices</key><array><string>_mimicam._tcp</string></array>
  <key>UIViewControllerBasedStatusBarAppearance</key><false/>
